# ── App ──────────────────────────────────────────────────────────────
APP_NAME=HomeFindr
APP_ENV=development                  # development | staging | production
DEBUG=true
API_V1_PREFIX=/api/v1
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Database (Railway PostgreSQL) ─────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/homefindr
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis (Railway Redis) ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security ──────────────────────────────────────────────────────────
SECRET_KEY=your-256-bit-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Google OAuth ──────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ── Stripe (Payments) ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_CURRENCY=ngn

# ── File Storage (Cloudflare R2 / AWS S3) ───────────────────────────
S3_BUCKET_NAME=homefindr-media
S3_REGION=auto
S3_ENDPOINT_URL=https://your-account.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_PUBLIC_URL=https://media.homefindr.ng

# ── Email (SendGrid / Resend) ────────────────────────────────────────
SENDGRID_API_KEY=SG.your-sendgrid-api-key
FROM_EMAIL=hello@homefindr.ng
FROM_NAME=HomeFindr

# ── SMS (Termii - Nigerian SMS gateway) ─────────────────────────────
TERMII_API_KEY=your-termii-api-key
TERMII_SENDER_ID=HomeFindr

# ── Rate Limiting ─────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ── Mapbox ────────────────────────────────────────────────────────────
MAPBOX_ACCESS_TOKEN=pk.your-mapbox-token

# ── Socket.IO ─────────────────────────────────────────────────────────
SOCKETIO_CORS_ORIGINS=http://localhost:3000
